# ============================================================
# AppBalance — variables de entorno (plantilla)
# ------------------------------------------------------------
# Copia este archivo a .env y rellena con tus valores reales:
#   cp .env.example .env
#
# Solo se usan estas dos. Ambas DEBEN llevar el prefijo EXPO_PUBLIC_
# o Expo no las inyecta al bundle (process.env las devolvería undefined).
# Las lee src/lib/supabase.ts al arrancar; reinicia `npx expo start`
# después de editarlas.
#
# Dónde: Supabase → Project Settings → API
#   EXPO_PUBLIC_SUPABASE_URL      = Project URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY = anon / public key  (NUNCA service_role)
#
# El .env real está en .gitignore y no se sube. La anon key es pública
# por diseño; la seguridad depende de la RLS, no de ocultarla.
# ============================================================

EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-public-key
