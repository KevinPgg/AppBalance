{
  "expo": {
    "name": "AppBalance",
    "slug": "appbalance",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "appbalance",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kevin.appbalance"
    },
    "android": {
      "package": "com.kevin.appbalance",
      "adaptiveIcon": {
        "backgroundColor": "#EFE7DC"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
